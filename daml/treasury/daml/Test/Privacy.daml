-- | Privacy verification tests for the treasury sandbox.
-- These tests verify that Canton's contract-level privacy works correctly:
-- different parties see different subsets of contracts.
module Test.Privacy where

import Daml.Script
import Treasury.Types
import Treasury.Strategy
import Treasury.Performance
import Treasury.Config
import Treasury.Epoch
import Treasury.Governance

-- | Test that other members CANNOT see a creator's ConfidentialStrategy
privacyTest_memberCannotSeeOthersStrategy : Script ()
privacyTest_memberCannotSeeOthersStrategy = script do
  operator <- allocateParty "operator"
  member1 <- allocateParty "member1"
  member2 <- allocateParty "member2"
  publicObserver <- allocateParty "publicObserver"

  -- Member1 creates a confidential strategy
  strategyCid <- submit member1 do
    createCmd ConfidentialStrategy with
      strategyId = "strat-1"
      name = "Blue Chip Hold"
      allocations = Allocation with weights = [("bitcoin", 0.5), ("ethereum", 0.3), ("usd-coin", 0.2)]
      epoch = 1
      status = Active
      creator = member1
      operator

  -- Member2 should NOT be able to see the strategy
  member2Visible <- queryContractId member2 strategyCid
  assertMsg "Member2 should NOT see Member1's ConfidentialStrategy" (member2Visible == None)

  -- Public observer should NOT see the strategy
  publicVisible <- queryContractId publicObserver strategyCid
  assertMsg "Public should NOT see ConfidentialStrategy" (publicVisible == None)

  pure ()

-- | Test that the creator CAN see their own strategy
privacyTest_creatorCanSeeOwnStrategy : Script ()
privacyTest_creatorCanSeeOwnStrategy = script do
  operator <- allocateParty "operator"
  member1 <- allocateParty "member1"

  strategyCid <- submit member1 do
    createCmd ConfidentialStrategy with
      strategyId = "strat-1"
      name = "Blue Chip Hold"
      allocations = Allocation with weights = [("bitcoin", 0.5), ("ethereum", 0.3), ("usd-coin", 0.2)]
      epoch = 1
      status = Active
      creator = member1
      operator

  -- Creator SHOULD see their own strategy
  creatorVisible <- queryContractId member1 strategyCid
  assertMsg "Creator SHOULD see own ConfidentialStrategy" (creatorVisible /= None)

  -- Operator (observer) SHOULD also see it
  operatorVisible <- queryContractId operator strategyCid
  assertMsg "Operator SHOULD see ConfidentialStrategy" (operatorVisible /= None)

  pure ()

-- | Test that all parties CAN see PerformanceReport contracts
privacyTest_allCanSeePerformance : Script ()
privacyTest_allCanSeePerformance = script do
  operator <- allocateParty "operator"
  member1 <- allocateParty "member1"
  member2 <- allocateParty "member2"
  publicObserver <- allocateParty "publicObserver"

  reportCid <- submit operator do
    createCmd PerformanceReport with
      strategyId = "strat-1"
      strategyName = "Blue Chip Hold"
      epoch = 1
      epochReturn = 0.05
      cumulativeReturn = 0.05
      maxDrawdown = 0.0
      operator
      members = [member1, member2]
      publicObserver

  -- All parties should see performance reports
  member1Visible <- queryContractId member1 reportCid
  assertMsg "Member1 SHOULD see PerformanceReport" (member1Visible /= None)

  member2Visible <- queryContractId member2 reportCid
  assertMsg "Member2 SHOULD see PerformanceReport" (member2Visible /= None)

  publicVisible <- queryContractId publicObserver reportCid
  assertMsg "Public SHOULD see PerformanceReport" (publicVisible /= None)

  pure ()

-- | Test that only the creator can update allocations
privacyTest_onlyCreatorCanUpdateAllocations : Script ()
privacyTest_onlyCreatorCanUpdateAllocations = script do
  operator <- allocateParty "operator"
  member1 <- allocateParty "member1"
  member2 <- allocateParty "member2"

  strategyCid <- submit member1 do
    createCmd ConfidentialStrategy with
      strategyId = "strat-1"
      name = "Blue Chip Hold"
      allocations = Allocation with weights = [("bitcoin", 0.5), ("ethereum", 0.3), ("usd-coin", 0.2)]
      epoch = 1
      status = Active
      creator = member1
      operator

  -- Member2 trying to update allocations should fail
  submitMustFail member2 do
    exerciseCmd strategyCid UpdateAllocations with
      newAllocations = Allocation with weights = [("bitcoin", 0.8), ("ethereum", 0.2)]
      currentEpoch = 2

  pure ()

-- | Test epoch advancement workflow
privacyTest_epochWorkflow : Script ()
privacyTest_epochWorkflow = script do
  operator <- allocateParty "operator"
  member1 <- allocateParty "member1"
  member2 <- allocateParty "member2"
  publicObserver <- allocateParty "publicObserver"

  epochCid <- submit operator do
    createCmd EpochState with
      currentEpoch = 0
      totalEpochs = 12
      phase = Completed
      operator
      members = [member1, member2]
      publicObserver

  -- Advance epoch
  epochCid2 <- submit operator do
    exerciseCmd epochCid AdvanceEpoch

  -- Verify epoch advanced
  Some epochState <- queryContractId operator epochCid2
  assertMsg "Epoch should be 1" (epochState.currentEpoch == 1)
  assertMsg "Phase should be Reporting" (epochState.phase == Reporting)

  -- Open voting
  epochCid3 <- submit operator do
    exerciseCmd epochCid2 OpenVoting

  Some epochState2 <- queryContractId operator epochCid3
  assertMsg "Phase should be Voting" (epochState2.phase == Voting)

  -- All parties should see epoch state
  member1Visible <- queryContractId member1 epochCid3
  assertMsg "Member1 should see EpochState" (member1Visible /= None)

  publicVisible <- queryContractId publicObserver epochCid3
  assertMsg "Public should see EpochState" (publicVisible /= None)

  pure ()
