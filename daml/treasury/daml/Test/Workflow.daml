-- | Full demo workflow test simulating the complete treasury sandbox lifecycle.
module Test.Workflow where

import Daml.Script
import Treasury.Types
import Treasury.Strategy
import Treasury.Performance
import Treasury.Governance
import Treasury.Config
import Treasury.Epoch

-- | Full end-to-end workflow test with 4-party model
fullDemoWorkflow : Script ()
fullDemoWorkflow = script do
  -- 1. Allocate all parties
  operator <- allocateParty "operator"
  member1 <- allocateParty "member1"
  member2 <- allocateParty "member2"
  publicObserver <- allocateParty "publicObserver"

  let allMembers = [member1, member2]

  -- 2. Create DAO Config
  _configCid <- submit operator do
    createCmd DAOConfig with
      operator
      members = allMembers
      publicObserver

  -- 3. Create Epoch State at epoch 0
  epochCid <- submit operator do
    createCmd EpochState with
      currentEpoch = 0
      totalEpochs = 12
      phase = Completed
      operator
      members = allMembers
      publicObserver

  -- 4. Member1 creates a strategy (CONFIDENTIAL - only creator + operator)
  strat1Cid <- submit member1 do
    createCmd ConfidentialStrategy with
      strategyId = "strat-bluechip"
      name = "Blue Chip Hold"
      allocations = Allocation with weights = [("bitcoin", 0.5), ("ethereum", 0.3), ("usd-coin", 0.2)]
      epoch = 0
      status = Active
      creator = member1
      operator

  -- 5. Member2 creates a different strategy
  strat2Cid <- submit member2 do
    createCmd ConfidentialStrategy with
      strategyId = "strat-degen"
      name = "Degen Yield"
      allocations = Allocation with weights = [("bitcoin", 0.2), ("ethereum", 0.8)]
      epoch = 0
      status = Active
      creator = member2
      operator

  -- 6. Advance to epoch 1
  epochCid1 <- submit operator do
    exerciseCmd epochCid AdvanceEpoch

  -- 7. Publish performance reports (PUBLIC - everyone can see)
  _report1 <- submit operator do
    createCmd PerformanceReport with
      strategyId = "strat-bluechip"
      strategyName = "Blue Chip Hold"
      epoch = 1
      epochReturn = 0.025
      cumulativeReturn = 0.025
      maxDrawdown = 0.0
      operator
      members = allMembers
      publicObserver

  _report2 <- submit operator do
    createCmd PerformanceReport with
      strategyId = "strat-degen"
      strategyName = "Degen Yield"
      epoch = 1
      epochReturn = -0.031
      cumulativeReturn = -0.031
      maxDrawdown = -0.031
      operator
      members = allMembers
      publicObserver

  -- 8. Open voting
  epochCid2 <- submit operator do
    exerciseCmd epochCid1 OpenVoting

  -- 9. Cast votes (PUBLIC - everyone can see who voted for what)
  _vote1 <- submit member1 do
    createCmd EliminationVote with
      voter = member1
      epoch = 1
      targetStrategyId = "strat-degen"
      operator
      members = allMembers
      publicObserver

  _vote2 <- submit member2 do
    createCmd EliminationVote with
      voter = member2
      epoch = 1
      targetStrategyId = "strat-bluechip"
      operator
      members = allMembers
      publicObserver

  -- 10. Close voting
  epochCid3 <- submit operator do
    exerciseCmd epochCid2 CloseVoting

  -- 11. Record elimination result (tie-break: strat-degen eliminated)
  _eliminationCid <- submit operator do
    createCmd EliminationResult with
      epoch = 1
      eliminatedStrategyId = "strat-degen"
      eliminatedStrategyName = "Degen Yield"
      voteTally = [("strat-degen", 1), ("strat-bluechip", 1)]
      operator
      members = allMembers
      publicObserver

  -- 12. Archive the eliminated strategy (operator exercises ArchiveStrategy)
  _archivedCid <- submit operator do
    exerciseCmd strat2Cid ArchiveStrategy with eliminationEpoch = 1

  -- 13. Verify privacy: member2 CANNOT see member1's strategy allocations
  member2Sees <- queryContractId member2 strat1Cid
  assertMsg "Member2 should NOT see Member1's strategy" (member2Sees == None)

  -- Member1 CAN see their own strategy
  member1Sees <- queryContractId member1 strat1Cid
  assertMsg "Member1 SHOULD see own strategy" (member1Sees /= None)

  -- All parties can see performance reports
  publicPerf <- query @PerformanceReport publicObserver
  assertMsg "Public should see performance reports" (length publicPerf == 2)

  -- Public can see elimination results
  publicEliminations <- query @EliminationResult publicObserver
  assertMsg "Public should see elimination results" (length publicEliminations == 1)

  -- 14. Eliminated member (member2) can create a new strategy
  _newStratCid <- submit member2 do
    createCmd ConfidentialStrategy with
      strategyId = "strat-recovery"
      name = "Recovery Play"
      allocations = Allocation with weights = [("bitcoin", 0.6), ("ethereum", 0.4)]
      epoch = 1
      status = Active
      creator = member2
      operator

  pure ()
